":null,"videoTemplateAppVersion":null,"videoTemplateDimensions":null},{"altText":"landscape - adapazari stok fotoğraflar ve resimler","fileType":null,"id":"508787285","assetId":"508787285","agreement":null,"agreements":[],"agreementDetails":[],"assetType":"image","family":"creative","editorialOnly":false,"licenseType":null,"quality":"Common","clipLength":null,"cirActionCount":null,"filmDefinition":null,"seoDuration":null,"filmPreviewUrl":null,"istockCollection":"Signature","editorialProducts":null,"eventName":null,"eventId":null,"eventDate":null,"eventUrlSlug":null,"thumbUrl":"https://media.istockphoto.com/id/508787285/tr/foto%C4%9Fraf/landscape.jpg?s=612x612\u0026w=0\u0026k=20\u0026c=lBv-TYCBJDQZ9awJw6BdMqIHcJm5JSxMoJQWzRJc1yE=","releaseCode":"NRR","mediaType":"Photography","dateSubmitted":"2014-08-26","slot":46,"isAnalogArchive":null,"isCallForImage":false,"isIstockSignature":true,"title":"Landscape","shortTitle":"Landscape","caption":"Landscape","colorIndexes":["489148"],"maxDimensions":{"width":612,"height":459},"people":"","artist":"prmustafa","collectionCode":null,"collectionName":null,"contributorDisplayName":"prmustafa","contributorMemberName":"prmustafa","collapsedImageCount":0,"collapsedVideoCount":0,"landingUrl":"/foto%C4%9Fraf/landscape-gm508787285-45614148","localizedCaption":null,"dateCreated":"14 Ağustos 2014","is360":null,"isAiEditable":true,"isFilm":false,"isOffline":null,"isExclusiveContent":false,"isEmbeddable":null,"seoTitle":"Landscape","seoCaption":"Landscape","orientation":"Horizontal","usageInfo":"|lisans koşulları| kapsamında izin verilen tüm kullanımlar için geçerlidir.","uploadDate":"2014-08-26T02:47:28Z","videoTemplateApp":null,"videoTemplateAppVersion":null,"videoTemplateDimensions":null},{"altText":"longoz flooded plains (water meadows) in adapazari - adapazari stok fotoğraflar ve resimler","fileType":null,"id":"489567424","assetId":"489567424","agreement":null,"agreements":[],"agreementDetails":[],"assetType":"image","family":"creative","editorialOnly":false,"licenseType":null,"quality":"Common","clipLength":null,"cirActionCount":null,"filmDefinition":null,"seoDuration":null,"filmPreviewUrl":null,"istockCollection":"Main","editorialProducts":null,"eventName":null,"eventId":null,"eventDate":null,"eventUrlSlug":null,"thumbUrl":"https://media.istockphoto.com/id/489567424/tr/foto%C4%9Fraf/longoz-flooded-plains-in-adapazari.jpg?s=612x612\u0026w=0\u0026k=20\u0026c=Nik2GjiDxXoa5bOfftAag72s7PXgKIfiZQ5ngD8WehA=","releaseCode":"NRR","mediaType":"Photography","dateSubmitted":"2015-10-02","slot":47,"isAnalogArchive":null,"isCallForImage":false,"isIstockSignature":false,"title":"longoz flooded plains (water meadows) in adapazari","shortTitle":"longoz flooded plains (water meadows) in adapazari","caption":"longoz in sakarya. Longoz Acarlar, located between Karasu and Kaynarca in the North of Sakarya, is the monolithic longoz of Turkey. Its extent is 250–1250 m and length is 7.5 km. In terms of forming, it is a typical lagoon. It is bordered with dune 20-25 high in The Black Sea region, low hills nearly 100m high in the South. It takes place 6 km away in the West of Sakarya.and much of water flows into Sakarya River via Okçu River. Some kinds of plants and animals some of which are partly endemic live in this lake. It is the area especially for the passagers for semination and spending their winter. Ashes, Brazils, Beeches and Elms are some of common types in the forest. Leucojum aestivum, used for the treatment of the Poliomyelitis, is traded by the villagers living in Kaynarca.","colorIndexes":["6d9148","6d6d48"],"maxDimensions":{"width":612,"height":408},"people":"","artist":"ilkercekic","collectionCode":null,"collectionName":null,"contributorDisplayName":"ilkercekic","contributorMemberName":"ilkercekic","collapsedImageCount":0,"collapsedVideoCount":0,"landingUrl":"/foto%C4%9Fraf/longoz-flooded-plains-in-adapazari-gm489567424-74733489","localizedCaption":null,"dateCreated":"23 Eylül 2015","is360":null,"isAiEditable":true,"isFilm":false,"isOffline":null,"isExclusiveContent":false,"isEmbeddable":null,"seoTitle":"Longoz flooded plains in adapazari","seoCaption":"Longoz in sakarya. Longoz Acarlar, located between Karasu and Kaynarca in the North of Sakarya, is the monolithic longoz of Turkey. Its extent is 250–1250 m and length is 7.5 km. In terms of forming, it is a typical lagoon. It is bordered with dune 20-25 high in The Black Sea region, low hills nearly 100m high in the South. It takes place 6 km away in the West of Sakarya.and much of water flows into Sakarya River via Okçu River. Some kinds of plants and animals some of which are partly endemic live in this lake. It is the area especially for the passagers for semination and spending their winter. Ashes, Brazils, Beeches and Elms are some of common types in the forest. Leucojum aestivum, used for the treatment of the Poliomyelitis, is traded by the villagers living in Kaynarca.","orientation":"Horizontal","usageInfo":"|lisans koşulları| kapsamında izin verilen tüm kullanımlar için geçerlidir.","uploadDate":"2015-10-02T04:16:12Z","videoTemplateApp":null,"videoTemplateAppVersion":null,"videoTemplateDimensions":null},{"altText":"7 centuries old sycamore tree in the center of taraklı district of sakarya province in turkey - adapazari stok fotoğraflar ve resimler","fileType":null,"id":"1332338520","assetId":"1332338520","agreement":null,"agreements":[],"agreementDetails":[],"assetType":"image","family":"creative","editorialOnly":false,"licenseType":null,"quality":"Common","clipLength":null,"cirActionCount":null,"filmDefinition":null,"seoDuration":null,"filmPreviewUrl":null,"istockCollection":"Main","editorialProducts":null,"eventName":null,"eventId":null,"eventDate":null,"eventUrlSlug":null,"thumbUrl":"https://media.istockphoto.com/id/1332338520/tr/foto%C4%9Fraf/7-centuries-old-sycamore-tree-in-the-center-of-tarakl%C4%B1-district-of-sakarya-province-in.jpg?s=612x612\u0026w=0\u0026k=20\u0026c=0Z4cE3VGYheQn_aLsRQcMfzlFz_N